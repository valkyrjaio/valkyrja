 */

use Valkyrja\Application\Constant\ComponentClass;
use Valkyrja\Application\Data\CliConfig;
use Valkyrja\Application\Entry\Cli;
use Valkyrja\Bin\Provider\ComponentProvider;

$composerAutoloadFilePossibilities = [
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../autoload.php',
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/vendor/autoload.php',
];

$dirPossibilities = [
    __DIR__ . '/../../../../',
    __DIR__ . '/../../../',
    __DIR__ . '/../',
    __DIR__ . '/',
];

$composerAutoloadFile = null;
$dir                  = null;

foreach ($composerAutoloadFilePossibilities as $key => $file) {
    if (file_exists($file)) {
        $composerAutoloadFile = $file;
        $dir                  = $dirPossibilities[$key];

        break;
    }
}

if ($composerAutoloadFile === null || $dir === null) {
    fwrite(
        \STDERR,
        'You need to set up the project dependencies using Composer:' . \PHP_EOL . \PHP_EOL
            . '    composer install' . \PHP_EOL . \PHP_EOL
            . 'You can learn all about Composer on https://getcomposer.org/.' . \PHP_EOL
    );

    exit(1);
}

/** @psalm-suppress UnresolvableInclude */
require $composerAutoloadFile;

define('BIN_APP_DIR', $dir);

$config = new CliConfig(
    dir: $dir,
    providers: [
        ComponentClass::CONTAINER,
        ComponentClass::DISPATCHER,
        ComponentClass::CLI_INTERACTION,
        ComponentClass::CLI_MIDDLEWARE,
        ComponentClass::CLI_ROUTING,
        ComponentClass::CLI_SERVER,
        ComponentClass::EVENT,
        ComponentClass::HTTP_MESSAGE,
        ComponentClass::HTTP_MIDDLEWARE,
        ComponentClass::HTTP_ROUTING,
        ComponentClass::HTTP_SERVER,
        ComponentProvider::class,
    ],
);

Cli::run($config);
